# ====================================
# Cipher Converter — Environment Config
# ====================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://mongo:27017/cipher-converter

# AES Encryption Secret Key (use a strong random string in production)
AES_SECRET_KEY=your-super-secret-key-change-me

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
